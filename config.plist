<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>ACPI</key>
    <dict>
        <key>Add</key>
        <array/>
        <key>Delete</key>
        <array/>
        <key>Patch</key>
        <array/>
        <key>Quirks</key>
        <dict>
            <key>FadtEnableReset</key><true/>
            <key>NormalizeHeaders</key><true/>
            <key>RebaseRegions</key><true/>
            <key>ResetLogoStatus</key><true/>
            <key>ResetHwSig</key><true/>
        </dict>
    </dict>
    <key>Booter</key>
    <dict>
        <key>Quirks</key>
        <dict>
            <key>AppleCpuPmCfgLock</key><true/>
            <key>AppleXcpmCfgLock</key><true/>
            <key>DisableIoMapper</key><false/>
            <key>EnableSafeModeSlide</key><true/>
            <key>ForceBooterSignature</key><false/>
        </dict>
    </dict>
    <key>CPU</key>
    <dict>
        <key>Count</key><integer>6</integer>
        <key>Frequency</key><integer>2700</integer>
    </dict>
    <key>DeviceProperties</key>
    <dict>
        <key>Add</key>
        <dict/>
    </dict>
    <key>Kernel</key>
    <dict>
        <key>Add</key>
        <array>
            <dict>
                <key>BundlePath</key>
                <string>Lilu.kext</string>
                <key>Enabled</key>
                <true/>
            </dict>
            <dict>
                <key>BundlePath</key>
                <string>VirtualSMC.kext</string>
                <key>Enabled</key>
                <true/>
            </dict>
            <dict>
                <key>BundlePath</key>
                <string>WhateverGreen.kext</string>
                <key>Enabled</key>
                <true/>
            </dict>
            <dict>
                <key>BundlePath</key>
                <string>AppleALC.kext</string>
                <key>Enabled</key>
                <true/>
            </dict>
            <dict>
                <key>BundlePath</key>
                <string>AirportItlwm.kext</string>
                <key>Enabled</key>
                <true/>
            </dict>
            <dict>
                <key>BundlePath</key>
                <string>NVMeFix.kext</string>
                <key>Enabled</key>
                <true/>
            </dict>
        </array>
    </dict>
    <key>NVRAM</key>
    <dict>
        <key>BootArgs</key>
        <string>-v keepsyms=1 debug=0x100</string>
        <key>csr-active-config</key>
        <data>Zw==</data> <!-- Désactive SIP -->
    </dict>
    <key>PlatformInfo</key>
    <dict>
        <key>Generic</key>
        <dict>
            <key>SystemProductName</key>
            <string>MacBookPro18,1</string>
            <key>SystemSerialNumber</key>
            <string>FB1234567890</string>
            <key>MLB</key>
            <string>FB1234567890123</string>
            <key>SystemUUID</key>
            <string>11111111-2222-3333-4444-555555555555</string>
        </dict>
    </dict>
    <key>UEFI</key>
    <dict>
        <key>Drivers</key>
        <array>
            <string>OpenRuntime.efi</string>
            <string>HfsPlus.efi</string>
        </array>
        <key>Quirks</key>
        <dict>
            <key>ExitBootServicesDelay</key><integer>0</integer>
        </dict>
    </dict>
</dict>
</plist>
